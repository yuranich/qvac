# MQTT Configuration
# Copy to .env and fill in values

MQTT_PROTOCOL=mqtts
MQTT_HOST=broker.example.com
MQTT_PORT=8883
MQTT_USERNAME=your-username
MQTT_PASSWORD=your-password

# Optional: TLS Certificates
# MQTT_CA_PATH=/path/to/ca.crt
# MQTT_CERT_PATH=/path/to/client.crt
# MQTT_KEY_PATH=/path/to/client.key
