#!/usr/bin/env bare
'use strict'

// QVAC OCR-GGML CLI — Optical Character Recognition Command-Line Tool
//
// Mirrors the surface of EasyOcr-ggml's `ocr-cli` binary, but driven from
// the @qvac/ocr-ggml bare addon (this package). Design follows the sibling
// `nmt-cli` in @qvac/translation-nmtcpp:
//   - shebang JS, parsed by `bare`
//   - logs to stderr, output to stdout (clean for piping / `jq`)
//   - env-var fallbacks for every path argument
//   - exit code 0 on success, 1 on runtime error, 2 on bad CLI usage
//
// This script is a development tool — it is intentionally NOT listed in
// `package.json` `files`, so it is not shipped to npm consumers (same
// convention as nmt-cli).
//
// Usage:
//   bare ocr-ggml-cli [OPTIONS]
//
// Reads an image file from --image (default: samples/english.png), runs the
// EasyOCR pipeline (CRAFT detect → bounding-box → CRNN gen-2 recognize) on
// GGUF weights, and prints recognized text to stdout. Output is sorted
// top-to-bottom by box y-center.

const process = require('bare-process')
const path = require('bare-path')
const fs = require('bare-fs')
const os = require('bare-os')

const { OcrGgml } = require('./index.js')

// JS mirror of easyocr::ggml::pipeline::defaultPhysicalThreadCount() — used
// only to render an honest "[load]   n-threads=..." line. Same heuristic:
// hardware_concurrency() / 2, floored at 1. Assumes 2-way SMT on x86; on
// non-SMT hosts this under-reports by 2× (the C++ side has the same caveat).
function defaultPhysicalThreadCount () {
  const hc = (typeof os.cpus === 'function' && os.cpus().length) || 1
  return Math.max(Math.floor(hc / 2), 1)
}

function describeNThreads (requested) {
  if (requested === 0) {
    return `${defaultPhysicalThreadCount()} (auto: physical cores)`
  }
  if (requested < 0) {
    const logical = (typeof os.cpus === 'function' && os.cpus().length) || 1
    return `~${logical} (GGML default: hardware_concurrency)`
  }
  return `${requested} (explicit)`
}

const VERSION = '0.1.0'

const DEFAULTS = {
  image: 'samples/english.png',
  detector: 'models/craft_mlt_25k.gguf',
  recognizer: 'models/english_g2.gguf',
  lang: 'en',
  pipelineType: 'easyocr',
  magRatio: 1.5,
  detail: 0,
  outputFormat: 'standard',
  nThreads: 0,
  paragraph: false,
  verbose: false
}

