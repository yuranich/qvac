    `                                   default: ${DEFAULTS.detector}`,
    '                                   env var: OCR_GGML_DETECTOR',
    '      --recognizer PATH            Recognizer GGUF file',
    '                                   easyocr: CRNN gen-2 model',
    '                                   doctr:   doctr recognition model',
    `                                   default: ${DEFAULTS.recognizer}`,
    '                                   env var: OCR_GGML_RECOGNIZER',
    '      --pipeline-type easyocr|doctr',
    '                                   OCR pipeline to use',
    `                                   default: ${DEFAULTS.pipelineType}`,
    '                                   env var: OCR_GGML_PIPELINE_TYPE',
    '      --lang CSV                   Comma-separated language codes (easyocr only)',
    `                                   default: ${DEFAULTS.lang}`,
    '      --paragraph                  Merge nearby boxes into paragraph regions',
    '      --mag-ratio FLOAT            Input-image magnification factor (easyocr only)',
    `                                   default: ${DEFAULTS.magRatio}`,
    '      --detail 0|1                 0 = text only, 1 = #<idx> conf=… box=… text=…',
    `                                   default: ${DEFAULTS.detail}`,
    '      --output-format standard|json',
    '                                   standard = human-readable lines',
    '                                   json     = EasyOCR-compatible array',
    `                                   default: ${DEFAULTS.outputFormat}`,
    '      --n-threads N                GGML CPU thread count',
    '                                   0 = auto (physical cores)',
    '                                   N > 0 = explicit',
    '                                   N < 0 = leave GGML default unchanged',
    `                                   default: ${DEFAULTS.nThreads}`,
    '      --verbose                    Forward C++ logs to stderr',
    '',
    'ENVIRONMENT VARIABLES:',
    '  OCR_GGML_IMAGE           Image path (alternative to --image)',
    '  OCR_GGML_DETECTOR        Detector GGUF (alternative to --detector)',
    '  OCR_GGML_RECOGNIZER      Recognizer GGUF (alternative to --recognizer)',
    '  OCR_GGML_PIPELINE_TYPE   Pipeline type (alternative to --pipeline-type)',
    '',
    'EXAMPLES:',
    '  # Default: OCR samples/english.png with EasyOCR weights',
