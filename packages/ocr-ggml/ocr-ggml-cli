    '',
    `QVAC OCR-GGML CLI v${VERSION} — Optical Character Recognition (GGML backend)`,
    '',
    'USAGE:',
    '  bare ocr-ggml-cli [OPTIONS]',
    '',
    'DESCRIPTION:',
    '  Runs an OCR pipeline on a single image using GGUF weights loaded via the',
    '  @qvac/ocr-ggml addon. Two pipelines are supported:',
    '    easyocr  CRAFT detector + CRNN gen-2 recognizer (default)',
    '    doctr    DBNet detector + doctr recognizer (language-agnostic)',
    '  Output is sorted top-to-bottom by box y-center.',
    '',
    'OPTIONS:',
    '  -h, --help                       Show this help message and exit',
    '  -v, --version                    Show version information and exit',
    '      --image PATH                 Input image (JPEG, PNG, or BMP)',
    `                                   default: ${DEFAULTS.image}`,
    '                                   env var: OCR_GGML_IMAGE',
    '      --detector PATH              Detector GGUF file',
    '                                   easyocr: CRAFT model',
