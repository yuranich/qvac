    '',
    '  # Custom image + Q8_0 quantized EasyOCR models',
    '  bare ocr-ggml-cli --image /tmp/photo.jpg \\',
    '                    --detector models/craft_mlt_25k_q8_0.gguf \\',
    '                    --recognizer models/english_g2_q8_0.gguf',
    '',
    '  # Force a specific thread count',
    '  bare ocr-ggml-cli --n-threads 8',
    '',
    '  # Verbose mode — print C++ pipeline logs to stderr',
    '  bare ocr-ggml-cli --verbose',
    '',
    'EXIT CODES:',
    '  0  Success',
    '  1  Runtime error (missing file, addon failure, image decode error, …)',
