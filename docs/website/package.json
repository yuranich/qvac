{
  "name": "qvac-docs",
  "version": "0.1.0",
  "description": "Official documentation and single source of truth for QVAC",
  "private": true,
  "scripts": {
    "prebuild:examples": "npx tsc --noCheck --noResolve --skipLibCheck --module ESNext --target ESNext --rootDir ../../packages/sdk/examples --outDir ../../packages/sdk/dist/examples ../../packages/sdk/examples/*.ts ../../packages/sdk/examples/**/*.ts",
    "build": "npm run prebuild:examples && next build && bun run scripts/generate-llm-md-files.ts && npx @vahor/next-broken-links",
    "build:static": "npm run prebuild:examples && next build && bun run scripts/generate-llm-md-files.ts && npx @vahor/next-broken-links",
    "dev": "npm run prebuild:examples && next dev --turbo -p 3001",
    "start": "next start",
    "serve": "http-server out -p 8080 -c-1",
    "postinstall": "patch-package && fumadocs-mdx",
    "docs:generate": "bun run scripts/run-docs-generate.ts",
    "docs:audit-tsdoc": "bun run scripts/api-docs/audit-tsdoc.ts",
    "docs:generate-api": "bun run scripts/generate-api-docs.ts",
    "docs:update-versions": "bun run scripts/update-versions-list.ts",
    "docs:create-version": "bun run scripts/create-version-bundle.ts",
    "docs:release-version-minor": "bun run scripts/release-version-minor.ts",
    "docs:release-version-patch": "bun run scripts/release-version-patch.ts",
    "docs:generate-release-notes": "bun run scripts/generate-release-notes.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:examples": "bun run scripts/test-code-examples.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.29",
    "@icons-pack/react-simple-icons": "^13.8.0",
    "@inkeep/cxkit-react": "^0.5.111",
    "@next/third-parties": "^16.2.0",
    "@orama/orama": "^3.1.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@tabler/icons-react": "^3.44.0",
    "ai": "^5.0.116",
    "altcha-lib": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "^16.3.2",
    "fumadocs-mdx": "^14.2.2",
    "fumadocs-ui": "^16.3.2",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.15.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "openai": "^6.38.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "dompurify": "^3.4.0",
    "uuid": "^11.1.1",
    "vite": "^7.3.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.3.3",
    "@types/nunjucks": "^3.2.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vahor/next-broken-links": "^0.4.1",
    "bun": "^1.3.11",
    "glob": "^11.0.3",
    "http-server": "^14.1.1",
    "nunjucks": "^3.2.4",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.10",
    "remark-code-import": "^1.2.0",
    "tailwindcss": "^4.1.13",
    "typedoc": "^0.28.17",
    "typedoc-plugin-zod": "^1.4.3",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
